{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Smoke Test Site Endpoints",
      "type": "shell",
      "command": "docker",
      "args": [
        "compose",
        "exec",
        "-T",
        "server",
        "python",
        "scripts/smoke_test_site_endpoints.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "Warm Clan Battle Fixture Cache",
      "type": "shell",
      "command": "docker",
      "args": [
        "compose",
        "exec",
        "-T",
        "server",
        "python",
        "manage.py",
        "shell",
        "-c",
        "from warships.tasks import warm_clan_battle_summaries_task; print(warm_clan_battle_summaries_task.run())"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}